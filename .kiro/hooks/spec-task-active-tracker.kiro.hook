{
  "name": "Track Active Spec",
  "version": "1.0.0",
  "description": "When a task starts, writes the spec folder path to .kiro/specs/.active-spec for other hooks to use.",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/track-active-spec.sh",
    "timeout": 5
  }
}