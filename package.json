{
  "name": "typocop",
  "version": "0.1.0",
  "description": "Code Graph Analyzer — precomputed relational intelligence for source code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "typocop": "dist/apps/cli/main.js",
    "typocop-mcp": "dist/apps/mcp-server/main.js",
    "typocop-ladybug-server": "dist/apps/ladybug-server/main.js"
  },
  "files": [
    "dist",
    "proto",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/apps/cli/main.js dist/apps/mcp-server/main.js dist/apps/ladybug-server/main.js",
    "postinstall": "pnpm approve-builds",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "RUN_BENCH=1 vitest run src/application/indexing/ingestion.bench.test.ts",
    "bench:parse": "RUN_BENCH=1 vitest run src/application/indexing/parsing.bench.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "depcruise": "depcruise --ignore-known=.dependency-cruiser-known-violations.json"
  },
  "keywords": [
    "code-analysis",
    "knowledge-graph",
    "ast",
    "tree-sitter"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/proper-lockfile": "^4.1.4",
    "dependency-cruiser": "^17.4.3",
    "fast-check": "^4.8.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@huggingface/transformers": "^4.2.0",
    "@ladybugdb/core": "^0.17.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ora": "^9.4.0",
    "proper-lockfile": "^4.1.2",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2"
  }
}
