# Embedding provider selection (huggingface | ollama | none)
# Default: huggingface (or ollama if OLLAMA_ENABLED=true for backward compat)
EMBEDDING_PROVIDER=huggingface

# HuggingFace cache directory (optional — defaults to ~/.cache/huggingface)
# HF_HOME=~/.cache/huggingface

# HuggingFace in-process embedding settings (used when EMBEDDING_PROVIDER=huggingface)
HF_MODEL=mixedbread-ai/mxbai-embed-large-v1
HF_DTYPE=fp32
HF_DIMENSIONS=1024
HF_POOLING=cls

# LadybugDB storage path (optional — defaults to ~/.typocop/{prefix}/db.ladybug)
# LADYBUGDB_PATH=

# Ollama local embeddings (optional — used when EMBEDDING_PROVIDER=ollama)
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mxbai-embed-large
OLLAMA_DIMENSIONS=1024
# Schema prefix for LadybugDB labels/relationship types.
# Default: tpc_ — change to isolate multiple Typocop instances in the same DB.
# Rules: lowercase letter start, lowercase alphanumeric + underscores, max 32 chars.
# Examples: tpc_  myapp_  prod_  dev_
TYPOCOP_PREFIX=tpc_